# ==============================================================================
# Vector MCP Environment Configuration
# ==============================================================================

# --- MCP Server Settings ---
HOST=127.0.0.1
PORT=8000
TRANSPORT=stdio # options: stdio, streamable-http, sse

# --- Telemetry and observability ---
ENABLE_OTEL=
# Configure the shared AgentConfig observability profile and runtime secret
# references. Content capture remains disabled unless governance explicitly enables it.

# --- Embedding model registry ---
# Configure AgentConfig EMBEDDING_MODELS and its referenced runtime credentials.
# EMBEDDING_TLS_PROFILE_REF=secret://runtime/embedding-tls-profile

# --- Vector store ---
# Required only for filesystem ingestion. Supply the operator-owned root at runtime.
DOCUMENT_DIRECTORY=
# Backend used when db_type is unspecified. Default is the native epistemic-graph
# engine (local, zero-infra, durable). Options: epistemic_graph, postgres,
# mongodb, qdrant.
DATABASE_TYPE=epistemic_graph
# The native engine is resolved by AgentConfig. Do not persist its transport or
# authentication material in this file.

# --- Tool Toggle Switches ---
COLLECTION_MANAGEMENTTOOL=True
SEARCHTOOL=True
