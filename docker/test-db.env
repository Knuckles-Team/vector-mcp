# Bootstrap env for the third-party database server images in compose.test.yml.
# These configure the Postgres/Couchbase container images themselves — they are
# NOT application config (the app never reads them; tests connect via the TEST_*
# vars in .env.example). Kept out of the compose `environment:` blocks so they are
# not mistaken for the app's env surface.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=vectordb
COUCHBASE_ADMINISTRATOR_USERNAME=Administrator
COUCHBASE_ADMINISTRATOR_PASSWORD=password
COUCHBASE_BUCKET=vector_db
COUCHBASE_BUCKET_RAMSIZE=256
